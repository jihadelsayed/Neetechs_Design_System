{
  "name": "@neetechs/ui",
  "version": "0.0.2",
  "description": "Official framework-agnostic Neetechs UI design system.",
  "license": "MIT",
  "author": "Neetechs",
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "style": "./src/index.css",
  "files": [
    "dist",
    "src",
    "docs",
    "README.md"
  ],
  "scripts": {
    "clean": "rimraf dist",
    "build": "tsc -p tsconfig.json && node scripts/copy-assets.mjs",
    "check:tokens": "node scripts/check-design-tokens.mjs",
    "check:a11y": "node scripts/check-accessibility.mjs",
    "check:rtl": "node scripts/check-rtl.mjs",
    "check:architecture": "node scripts/check-component-architecture.mjs",
    "check:states": "node scripts/check-state-contracts.mjs",
    "test:unit": "node --test \"tests/**/*.test.mjs\"",
    "test:browser": "npm run build && playwright test",
    "test": "npm run check:tokens && npm run check:a11y && npm run check:rtl && npm run check:architecture && npm run check:states && npm run build && npm run test:unit",
    "pack:local": "npm run build && npm pack",
    "release": "semantic-release"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./styles": "./src/index.css",
    "./styles.css": "./src/index.css",
    "./base.css": "./src/styles/index.css",
    "./tokens.css": "./src/styles/tokens/index.css",
    "./reset.css": "./src/styles/reset.css",
    "./themes/dark.css": "./src/styles/themes/dark.css",
    "./themes/light.css": "./src/styles/themes/light.css",
    "./themes/high-contrast.css": "./src/styles/themes/high-contrast.css",
    "./utilities/layout.css": "./src/styles/utilities/layout.css",
    "./utilities/text.css": "./src/styles/utilities/text.css",
    "./utilities/visibility.css": "./src/styles/utilities/visibility.css",
    "./localization.css": "./src/styles/localization.css",
    "./animations/motion.css": "./src/styles/animations/motion.css",
    "./shell.css": "./src/shell/index.css",
    "./shell/right-drawer.css": "./src/components/drawer/drawer.css",
    "./shell/*.css": "./src/shell/*/*.css",
    "./components.css": "./src/components/index.css",
    "./components/modal.css": "./src/components/dialog/dialog.css",
    "./components/*.css": "./src/components/*/*.css",
    "./patterns.css": "./src/patterns/index.css",
    "./patterns/workspace-switcher.css": "./src/patterns/company-switcher/company-switcher.css",
    "./patterns/*.css": "./src/patterns/*/*.css",
    "./ai.css": "./src/ai/index.css",
    "./ai/*.css": "./src/ai/*/*.css",
    "./domain.css": "./src/domain/index.css",
    "./domain/calendar.css": "./src/domain/calendar/index.css",
    "./domain/calendar/*.css": "./src/domain/calendar/*/*.css",
    "./domain/billing.css": "./src/domain/billing/index.css",
    "./domain/companies.css": "./src/domain/companies/index.css",
    "./appearance": {
      "types": "./dist/appearance/index.d.ts",
      "import": "./dist/appearance/index.js"
    },
    "./behaviors": {
      "types": "./dist/behaviors/index.d.ts",
      "import": "./dist/behaviors/index.js"
    },
    "./behaviors/*": {
      "types": "./dist/behaviors/*.d.ts",
      "import": "./dist/behaviors/*.js"
    },
    "./localization": {
      "types": "./dist/localization/index.d.ts",
      "import": "./dist/localization/index.js"
    },
    "./types": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/types/index.js"
    }
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@playwright/test": "^1.61.1",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/github": "^12.0.9",
    "@semantic-release/npm": "^13.1.5",
    "@semantic-release/release-notes-generator": "^14.1.1",
    "rimraf": "^6.0.1",
    "semantic-release": "^25.0.7",
    "typescript": "^5.8.3"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jihadelsayed/Neetechs_Design_System.git"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "directories": {
    "doc": "docs",
    "test": "tests"
  },
  "keywords": [],
  "bugs": {
    "url": "https://github.com/jihadelsayed/Neetechs_Design_System/issues"
  },
  "homepage": "https://github.com/jihadelsayed/Neetechs_Design_System#readme"
}
